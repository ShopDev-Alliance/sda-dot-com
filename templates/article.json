          }
        },
        "author_card": {
          "type": "author_card",
          "settings": {}
        },
        "prev_next": {
          "type": "prev_next",
          "settings": {}
        },
        "newsletter": {
          "type": "newsletter",
          "settings": {
            "heading": "Get more articles like this",
